POSTGRES_URL=postgresql://sentiql_app:sentiql_app@127.0.0.1:5432/sentiql
POLICY_MODE=read-only
POLICY_BUNDLE_PATH=./config/policy.example.json
OIDC_TOKEN_FILE=/run/secrets/agentconnect-oidc-token
AUDIT_DB_PATH=./data/audit.sqlite
DASHBOARD_PORT=3030
DASHBOARD_HOST=127.0.0.1
ENABLE_RAW_QUERY_COMPATIBILITY=false
# Required only when ENABLE_RAW_QUERY_COMPATIBILITY=true.
RAW_QUERY_BREAK_GLASS_REASON=

# Non-enforcing AST policy shadow mode; stores SQL digests and safe metadata only.
ENABLE_AST_POLICY_SHADOW=false
# Used only when shadow mode is enabled; must be a supported parser version.
AST_POLICY_SHADOW_PARSER_VERSION=16
